# Weights & Biases
# Leave WANDB_API_KEY empty if you plan to run `wandb login` manually.
WANDB_API_KEY=
WANDB_PROJECT=ddp-vision
WANDB_ENTITY=
WANDB_MODE=online

# Paths
DATA_DIR=/workspace/data/cifar10-imagefolder
WORK_DIR=/workspace/runs
EXPERIMENT_NAME=resnet50-runpod-ddp

# Training
NUM_CLASSES=10
NUM_PROCESSES=2
BATCH_SIZE=128
EPOCHS=10
SAVE_CHECKPOINT_INTERVAL=1
GRADIENT_ACCUMULATION_STEPS=1
LEARNING_RATE=0.1
WEIGHT_DECAY=1e-4
MOMENTUM=0.9
STEP_LR_DECAY=0.1
LR_STEP_SIZE=30
LR_WARMUP_EPOCHS=0
MAX_GRAD_NORM=1.0
IMG_SIZE=224
NUM_WORKERS=8
MIXED_PRECISION=bf16
LOG_WITH=wandb
